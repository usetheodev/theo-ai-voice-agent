# ===== Simple Asterisk Dockerfile using official image =====
FROM asterisk/asterisk:20

# Install additional utilities
USER root
RUN apt-get update && apt-get install -y \
    tcpdump \
    net-tools \
    vim \
    netcat \
    && rm -rf /var/lib/apt/lists/*

# Create directories
RUN mkdir -p /etc/asterisk/keys \
             /usr/share/asterisk/static-http

# Copy configurations
COPY config/* /etc/asterisk/

# Copy Browser-Phone files (clone from GitHub)
WORKDIR /tmp
RUN apt-get update && apt-get install -y git && \
    git clone https://github.com/InnovateAsterisk/Browser-Phone.git && \
    cp -r Browser-Phone/Phone /usr/share/asterisk/static-http/ && \
    rm -rf Browser-Phone && \
    apt-get remove -y git && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

# Copy entrypoint
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Set ownership
RUN chown -R asterisk:asterisk /etc/asterisk \
                                /usr/share/asterisk/static-http

# Expose ports
EXPOSE 5060/udp 5060/tcp
EXPOSE 8088/tcp 8089/tcp
EXPOSE 10000-10100/udp

# Health check
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=40s \
    CMD asterisk -rx "core show version" || exit 1

# Switch to asterisk user
USER asterisk

# Use entrypoint
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
