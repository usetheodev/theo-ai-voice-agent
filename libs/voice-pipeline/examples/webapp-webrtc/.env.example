# Voice Pipeline WebRTC Demo - Environment Configuration

# =============================================================================
# HuggingFace Token (Recommended)
# =============================================================================
# Get your token at: https://huggingface.co/settings/tokens
# This enables faster downloads and higher rate limits for models
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Provider: anthropic, ollama, openai
LLM_PROVIDER=ollama

# Model name
# For Ollama (local, no API key needed):
#   - qwen2.5:0.5b (recommended - fast, no thinking mode)
#   - qwen3:0.6b (fast but has "thinking mode" that shows internal reasoning)
#   - llama3.2:1b (balanced speed/quality)
#   - llama3.2:3b (slower, better quality - GPU recommended)
# For Anthropic (requires API key):
#   - claude-3-5-haiku-20241022 (fast, affordable)
#   - claude-sonnet-4-20250514 (best quality)
LLM_MODEL=qwen2.5:0.5b

# API Key (required for anthropic/openai)
# ANTHROPIC_API_KEY=your-api-key-here

# Base URL (optional, for custom endpoints)
# LLM_BASE_URL=http://localhost:11434/v1

# =============================================================================
# TTS (Text-to-Speech) Configuration
# =============================================================================

# Provider: kokoro, elevenlabs, openai
TTS_PROVIDER=kokoro

# Voice name (for Kokoro, use pf_ prefix for Portuguese voices)
# Available PT-BR voices: pf_dora, pf_camille, pm_alex
TTS_VOICE=pf_dora

# =============================================================================
# ASR (Automatic Speech Recognition) Configuration
# =============================================================================

# Provider: parakeet (recommended), faster-whisper
# Parakeet: NVIDIA's state-of-the-art ASR, ~6% WER, 25 languages, INT8 optimized
# Faster-Whisper: OpenAI Whisper with CTranslate2, good quality, more languages
ASR_PROVIDER=parakeet

# Model (only for faster-whisper): tiny, base, small, medium, large
ASR_MODEL=base

# Language code (pt = Portuguese, en = English, etc.)
ASR_LANGUAGE=pt

# =============================================================================
# Memory Configuration
# =============================================================================

# Enable episodic memory
MEMORY_ENABLED=true

# Path to store episode files
MEMORY_STORE_PATH=./episodes

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind to
HOST=0.0.0.0

# Port to listen on
PORT=8000

# Enable debug mode (auto-reload)
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=*

# =============================================================================
# System Prompt (optional - default is Portuguese)
# =============================================================================

# SYSTEM_PROMPT=Voce e um assistente de voz prestativo e amigavel. Responda de forma concisa e natural.
