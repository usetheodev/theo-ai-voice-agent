# ==============================================================================
# AI VOICE AGENT - Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust the values as needed
# ==============================================================================

# -----------------------------------------------------------------------------
# SIP Configuration
# -----------------------------------------------------------------------------
SIP_HOST=0.0.0.0
SIP_PORT=5060
SIP_REALM=voiceagent

# -----------------------------------------------------------------------------
# RTP Configuration
# -----------------------------------------------------------------------------
RTP_PORT_START=10200
RTP_PORT_END=10300
RTP_BUFFER_SIZE=4194304  # 4MB

# -----------------------------------------------------------------------------
# AI Models Configuration
# -----------------------------------------------------------------------------
# ASR (Automatic Speech Recognition) Provider
ASR_PROVIDER=distil-whisper  # Options: whisper, distil-whisper, parakeet

# Whisper (ASR - Automatic Speech Recognition) - Legacy provider
WHISPER_MODEL=base  # Options: tiny, base, small, medium, large-v3

# Distil-Whisper (ASR - 6x faster than Whisper)
DISTIL_WHISPER_MODEL=distil-large-v3  # Options: distil-large-v3, freds0/distil-whisper-large-v3-ptbr
DISTIL_WHISPER_LANGUAGE=pt  # Language code (pt, en, es) or "auto" for detection
DISTIL_WHISPER_DEVICE=cpu  # cpu or cuda
DISTIL_WHISPER_COMPUTE_TYPE=int8  # int8 (CPU), float16 (GPU), float32 (GPU)
DISTIL_WHISPER_BEAM_SIZE=5  # 1-10 (higher = better quality, slower)

# Parakeet TDT (NVIDIA NeMo ASR - ultra-fast, 6.32% WER)
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v3  # Options: nvidia/parakeet-tdt-0.6b-v3 (25 langs), nvidia/parakeet-tdt-0.6b-v2 (EN only)
PARAKEET_DEVICE=auto  # auto, cpu, cuda (auto = detect GPU)
PARAKEET_USE_ONNX=false  # true for CPU optimization (ONNX INT8)

# LLM (Large Language Model)
LLM_MODEL=phi-3-mini  # Options: phi-3-mini, mistral-7b, Qwen/Qwen2.5-7B

# TTS (Text-to-Speech)
TTS_VOICE=pt_BR-faber-medium

# -----------------------------------------------------------------------------
# GPU Configuration
# -----------------------------------------------------------------------------
# Set to empty string to use CPU only
# Set to "0" to use first GPU
# Set to "0,1" to use multiple GPUs
CUDA_VISIBLE_DEVICES=0

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
METRICS_PORT=8001
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
APP_ENV=development  # Options: development, staging, production

# =====================================
# Phase 1: Audio Quality Components (v2.2)
# =====================================

# RNNoise Filter (Noise Reduction)
RNNOISE_ENABLED=true
RNNOISE_QUALITY=QQ  # Options: VHQ, HQ, MQ, LQ, QQ (QQ = Quick, lowest latency)

# Silero VAD (ML-based Voice Activity Detection)
SILERO_VAD_ENABLED=true
SILERO_CONFIDENCE=0.5  # Threshold: 0.0-1.0 (0.5 = balanced)
SILERO_START_FRAMES=3  # Frames to confirm speech start
SILERO_STOP_FRAMES=10  # Frames to confirm speech end
SILERO_MIN_SPEECH_FRAMES=5  # Minimum frames for valid speech
SILERO_MODEL_PATH=  # Auto-download if empty

# SOXR Resampler (High-Quality Audio Resampling)
SOXR_ENABLED=true
SOXR_QUALITY=VHQ  # Options: VHQ, HQ, MQ, LQ, QQ (VHQ = Very High Quality)

# =====================================
# Phase 2.1: Conversational Intelligence (v2.3)
# =====================================

# Turn Detection (End-of-Turn Analysis)
TURN_DETECTION_ENABLED=true
TURN_DETECTION_PAUSE_DURATION=1.0  # Seconds of silence to declare end-of-turn (0.8-1.2s recommended)
TURN_DETECTION_MIN_DURATION=0.3    # Minimum speech duration to consider valid turn (0.2-0.5s)

# Smart Barge-in (Interruption Strategy)
INTERRUPTION_ENABLED=true
INTERRUPTION_MIN_DURATION=0.8  # Minimum speech duration to allow interruption (0.5-1.0s recommended)
