# =====================================
# AI Voice Agent - Environment Variables
# =====================================

# Whisper (ASR)
WHISPER_MODEL=base  # Options: tiny, base, small, medium

# LLM
LLM_MODEL=phi-3-mini  # Options: phi-3-mini, mistral-7b

# TTS
TTS_VOICE=pt_BR-faber-medium

# FreeSWITCH
FREESWITCH_PASSWORD=ChangeMe123!
AI_AGENT_HOST=ai-agent
AI_AGENT_PORT=5080

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR

# RTP
RTP_PORT=5080
RTP_BUFFER_SIZE=4194304  # 4MB

# Application
APP_ENV=development  # Options: development, staging, production

# =====================================
# Phase 1: Audio Quality Components (v2.2)
# =====================================

# RNNoise Filter (Noise Reduction)
RNNOISE_ENABLED=true
RNNOISE_QUALITY=QQ  # Options: VHQ, HQ, MQ, LQ, QQ (QQ = Quick, lowest latency)

# Silero VAD (ML-based Voice Activity Detection)
SILERO_VAD_ENABLED=true
SILERO_CONFIDENCE=0.5  # Threshold: 0.0-1.0 (0.5 = balanced)
SILERO_START_FRAMES=3  # Frames to confirm speech start
SILERO_STOP_FRAMES=10  # Frames to confirm speech end
SILERO_MIN_SPEECH_FRAMES=5  # Minimum frames for valid speech
SILERO_MODEL_PATH=  # Auto-download if empty

# SOXR Resampler (High-Quality Audio Resampling)
SOXR_ENABLED=true
SOXR_QUALITY=VHQ  # Options: VHQ, HQ, MQ, LQ, QQ (VHQ = Very High Quality)
